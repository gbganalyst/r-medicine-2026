```{r timing-chart, fig.height=2.5, fig.width=6.2}
tibble(
  stage   = factor(
    c("Before bulkreadr\n(manual clicks)", "After bulkreadr\n(scripted)"),
    levels = c("After bulkreadr\n(scripted)", "Before bulkreadr\n(manual clicks)")
  ),
  minutes  = c(40, 2.5),
  fill_col = c("#EF4444", "#02C39A")
) |>
  ggplot(aes(x = minutes, y = stage, fill = fill_col)) +
  geom_col(width = 0.55, show.legend = FALSE) +
  geom_text(
    aes(label = ifelse(minutes > 10, "40 min", "< 3 min")),
    hjust = -0.15, size = 5, fontface = "bold",
    colour = c("#02C39A", "#EF4444")
  ) +
  scale_fill_identity() +
  scale_x_continuous(limits = c(0, 52), expand = c(0, 0)) +
  labs(title = "Data-loading time: before vs. after bulkreadr",
       x = "Minutes", y = NULL) +
  theme_bulkreadr() +
  theme(
    panel.grid.major.y = element_blank(),
    axis.text.y = element_text(size = 12, colour = "#334155")
  )
```

